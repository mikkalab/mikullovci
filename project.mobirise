    "cant_quarantine_art.html": {
      "settings": {
        "meta_descr": "The exhibition \"CAN'T QUARANTINE ART\" is an exhibition of first and second year students at the Department of Graphic Design and Visual Arts - AAB Faculty of Arts.",
        "title": "Besim Mikullovci | Can't Quarantine Art",
        "order": 10,
        "header_custom": ""
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            ".navbar": {
              "background": "@menuBgColor",
