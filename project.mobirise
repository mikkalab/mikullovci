    "expo.html": {
      "settings": {
        "meta_descr": "The Exhibition consist 16 Postmodern and digital photography works of art  which through the Personal Exhibition \"Tired of Isolation?\" aims to sensitize and raise awareness of the wider international public regarding the denial of the basic right to free movement.\nWe are geographically located in Europe!\n\nThe exhibited works represent my revolt against the unjust isolation of our country over the last 22 years.",
        "title": "Besim Mikullovci | Tired of isolation",
        "order": 11,
        "header_custom": ""
      },
