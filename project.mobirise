    "virtualstudio.html": {
      "settings": {
        "meta_descr": "I offer a Virtual Studio Design service,  creating, branding & implementing your very own custom green screen virtual set for your video production.\n\nJust give me a green screen footage, and I’ll make your broadcasts stand apart from the competition.\n",
        "title": "Besim Mikullovci | Virtual Set Design",
        "order": 16,
        "header_custom": ""
      },
      "components": [
