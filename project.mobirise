                "videoPreview": "@THEME_PATH@/components/_images/gallery/preview.jpg",
                "playVideo": false,
                "videoUrl": "https://www.youtube.com/watch?v=fwkKc6M60-0",
                "image": "@PROJECT_PATH@/assets/images/fahri-beqiri-1000x1276.jpg",
                "thumb": "@PROJECT_PATH@/assets/images/fahri-beqiri-1000x1276-800x1021.jpg",
