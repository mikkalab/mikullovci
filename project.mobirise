                "videoUrl": "https://www.youtube.com/watch?v=fwkKc6M60-0",
                "image": "@PROJECT_PATH@/assets/images/art-gashi-1654x2339.jpg",
                "thumb": "@PROJECT_PATH@/assets/images/art-gashi-1654x2339-800x1131.jpg",
                "alt": "",
